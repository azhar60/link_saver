<div id="<%= dom_id link %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Url:</strong>
    <%= link.url %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= link.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Summary:</strong>
    <%= link.summary %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Tags:</strong>
    <%= link.tags %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Status:</strong>
    <%= link.status %>
  </div>
</div>
