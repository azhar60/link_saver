<% content_for :title, "Links" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-700 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-3xl text-gray-900">Links</h1>
    <%= link_to "New link", new_link_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
  </div>

  <% if @links.any? %>
    <div id="links" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <%= render @links %>
    </div>
  <% else %>
    <div class="text-center py-16 border-2 border-dashed border-gray-200 rounded-lg">
      <p class="text-gray-500 mb-4">No links yet.</p>
      <%= link_to "Save your first link", new_link_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
    </div>
  <% end %>
</div>
